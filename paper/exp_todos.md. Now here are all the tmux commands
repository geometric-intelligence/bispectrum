Good. Now here are all the tmux commands. Let me put together a comprehensive script.

Here's your full tmux command block. Copy-paste this into a terminal -- it creates a tmux session called experiments with separate windows for each job:

tmux new-session -d -s experiments -n organ3d
# Window 1: OrganMNIST3D wider channels multi-seed (~8 runs, ~3 GPU-hours)
tmux send-keys -t experiments:organ3d \
  'cd /home/johmathe/bispectrum/paper/experiments/organ3d && source /home/johmathe/bispectrum/.venv/bin/activate && export PYTHONPATH="/home/johmathe/bispectrum/src:${PYTHONPATH:-}" && ./run_wider_multiseed.sh 2>&1 | tee wider_multiseed.log' Enter


# Window 2: Spherical MNIST data efficiency (~36 runs, ~6 GPU-hours)
tmux new-window -t experiments -n smnist
tmux send-keys -t experiments:smnist \
  'cd /home/johmathe/bispectrum/paper/experiments/spherical_mnist && source /home/johmathe/bispectrum/.venv/bin/activate && export PYTHONPATH="/home/johmathe/bispectrum/src:${PYTHONPATH:-}" && ./run_data_efficiency.sh 2>&1 | tee data_efficiency.log' Enter
# Window 3: PCam pareto phase-b (~64 runs, ~16-32 GPU-hours)
tmux new-window -t experiments -n pcam-pareto
tmux send-keys -t experiments:pcam-pareto \
  'cd /home/johmathe/bispectrum/paper/experiments/pcam && source /home/johmathe/bispectrum/.venv/bin/activate && export PYTHONPATH="/home/johmathe/bispectrum/src:${PYTHONPATH:-}" && ./run_matched_sweep.sh --phase-b 2>&1 | tee pareto_phaseb.log' Enter
# Window 4: PCam data-pareto phase-b (~72 runs, ~18-36 GPU-hours)
tmux new-window -t experiments -n pcam-data
tmux send-keys -t experiments:pcam-data \
  'cd /home/johmathe/bispectrum/paper/experiments/pcam && source /home/johmathe/bispectrum/.venv/bin/activate && export PYTHONPATH="/home/johmathe/bispectrum/src:${PYTHONPATH:-}" && ./run_data_pareto_sweep.sh --phase-b 2>&1 | tee data_pareto_phaseb.log' Enter
# Window 5: Inversion benchmark (~5 min)
